# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=todo_app

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_super_secret_key_32chars
JWT_REFRESH_SECRET=change_me_refresh_super_secret_key_32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Session ──────────────────────────────────────────
SESSION_SECRET=change_me_session_secret_32chars

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── External APIs ────────────────────────────────────
GEMINI_API_KEY=
