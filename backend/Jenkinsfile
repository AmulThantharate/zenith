pipeline {
  agent any 
  tools {
    nodejs "node25"
  }
  environment {
    SONAR_HOME = tool "sonar"
  }
  stages {
    stage("Checkout") {
      steps{
        git branch: "ci/jenkins", url: "https://github.com/AmulThantharate/zenith.git"
      }
    }

    stage("Imaeg Tag") {
      steps{
        script{
          env.IMAGE_TAG = sh(script: 'git log -1 --format="%h"', returnStdout: true).trim()
        }
      }
    }

    stage('Install Dependencies & Test') {
            parallel {
                stage('Install Dependencies') {
                    steps {
                        dir('backend') {
                            sh '''
                                echo "=== Installing Dependencies ==="
                                npm ci --prefer-offline --no-audit
                            '''
                        }
                    }
                }
                stage('Lint') {
                    steps {
                        dir('backend') {
                            sh '''
                                echo "=== Running Linter ==="
                                npm run lint || true
                            '''
                        }
                    }
                }
          }
    }

    stage('SonarQube Analysis') {
      steps {
          dir('backend') {
              withSonarQubeEnv('sonar') {
                  sh """
                      echo "=== Running SonarQube Analysis ==="
                      ${SONAR_HOME}/bin/sonar-scanner \
                                -Dsonar.projectName='BackendService' \
                                -Dsonar.projectKey='BackendService' \
                                -Dsonar.sources=. \
                                -Dsonar.tests=. \
                                -Dsonar.test.inclusions=**/*.test.js,**/*.spec.js \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.coverage.exclusions=**/*.test.js,**/*.spec.js,**/node_modules/**
                        """
                    }
                }
            }
        }
    stage("Quality Gate"){
        steps{
            timeout(time: 5, unit:"MINUTES"){
                waitForQualityGate abortPipeline: true
            }
        }
    }
  
    stage("Trivy File System") {
      stage("Trivy File System Scan") {
            steps {
                sh "mkdir -p reports && trivy fs --format table -o reports/trivy-fs-report.html ."
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports/',
                        reportFiles: 'trivy-fs-report.html',
                        reportName: 'Trivy FS Scan'
                    ])
                }
            }
        }
    }
  }
}