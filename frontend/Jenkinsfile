pipeline {
  agent any 
  tools {
    nodejs "node25"
  }
  environment {
    SONAR_HOME = tool "sonar"

    IMAGE_NAME          = 'claw4321/zenith-frontend'
    DOCKER_REGISTRY_URL = 'https://index.docker.io/v1/'
    TRIVY_SEVERITY      = 'HIGH,CRITICAL'
    TRIVY_EXIT_CODE     = '0'
    SYFT_FORMAT         = 'spdx-json'
  }
  stages {
    stage("Checkout") {
      steps{
        git branch: "ci/jenkins", url: "https://github.com/AmulThantharate/zenith.git"
      }
    }

    stage("Imaeg Tag") {
      steps{
        script{
          env.IMAGE_TAG = sh(script: 'git log -1 --format="%h"', returnStdout: true).trim()
        }
      }
    }

    stage('Install Dependencies & Test') {
            parallel {
                stage('Install Dependencies') {
                    steps {
                        dir('frontend') {
                            sh '''
                                echo "=== Installing Dependencies ==="
                                npm ci --prefer-offline --no-audit
                            '''
                        }
                    }
                }
                stage('Lint') {
                    steps {
                        dir('frontend') {
                            sh '''
                                echo "=== Running Linter ==="
                                npm run lint || true
                            '''
                        }
                    }
                }
          }
    }

    stage('SonarQube Analysis') {
      steps {
          dir('frontend') {
              withSonarQubeEnv('sonar') {
                  sh """
                      echo "=== Running SonarQube Analysis ==="
                      ${SONAR_HOME}/bin/sonar-scanner \
                                -Dsonar.projectName='FrontendService' \
                                -Dsonar.projectKey='FrontendService' \
                                -Dsonar.sources=. \
                                -Dsonar.tests=. \
                                -Dsonar.test.inclusions=**/*.test.js,**/*.spec.js \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.coverage.exclusions=**/*.test.js,**/*.spec.js,**/node_modules/**
                        """
                    }
                }
            }
    }

    stage("Quality Gate"){
        steps{
            timeout(time: 5, unit:"MINUTES"){
                waitForQualityGate abortPipeline: true
            }
        }
    }

    stage("Trivy File System Scan") {
            steps {
                sh "mkdir -p reports && trivy fs --format table -o reports/trivy-fs-report.html ."
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports/',
                        reportFiles: 'trivy-fs-report.html',
                        reportName: 'Trivy FS Scan'
                    ])
                }
            }
    }

    stage("Docker Build and Tag") {
        steps {
            dir('frontend') {
                sh "docker build -t zenith-frontend:${IMAGE_TAG} ."
                sh "docker tag zenith-frontend:${IMAGE_TAG} ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }

    stage('Security Scans') {
            parallel {
                stage('Trivy Vulnerability Scan') {
                    steps {
                        sh """
                            echo "=== Running Trivy Scan ==="
                            trivy image \
                                --severity ${env.TRIVY_SEVERITY} \
                                --exit-code ${env.TRIVY_EXIT_CODE} \
                                --format table \
                                --scanners vuln \
                                --timeout 10m \
                                ${env.IMAGE_NAME}:${env.IMAGE_TAG}
                        """
                    }
                    post {
                        always {
                            sh """
                                echo "=== Generating Trivy SBOM ==="
                                trivy image \
                                    --format cyclonedx \
                                    --output trivy-frontend-sbom.json \
                                    ${env.IMAGE_NAME}:${env.IMAGE_TAG}
                            """
                            archiveArtifacts artifacts: 'trivy-frontend-sbom.json', allowEmptyArchive: true
                        }
                    }
                }
                stage('Syft SBOM Generation') {
                    steps {
                        sh """
                            echo "=== Generating SBOM with Syft ==="
                            syft ${env.IMAGE_NAME}:${env.IMAGE_TAG} \
                                -o ${env.SYFT_FORMAT} > syft-frontend-sbom.json
                        """
                        archiveArtifacts artifacts: 'syft-frontend-sbom.json', allowEmptyArchive: true
                    }
                }
            }
    }

    stage("Docker Push") {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'DOCKER_CRED',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    docker push $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
        }
        post {
                success {
                    sh """
                        echo "=== Image Digest ==="
                        docker inspect --format='{{index .RepoDigests 0}}' ${env.IMAGE_NAME}:${env.IMAGE_TAG} \
                            || echo "Digest not available locally"
                    """
                }
        }
    }
  }
}
